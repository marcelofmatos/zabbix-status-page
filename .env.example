# --- Zabbix (required) ---
ZABBIX_URL=https://zabbix.example.com/zabbix/
# Requires Zabbix >= 6.4 (token auth via the Authorization: Bearer header)
ZABBIX_TOKEN=put-your-api-token-here
ZABBIX_GROUPS_IDS=
ZABBIX_HOSTS_IDS=
ZABBIX_STATUS_BY_GROUPS=on
ZABBIX_KNOWLEADS=on
ZABBIX_KNOWLEADS_COMMENTS=on

# --- Presentation (comes from the container environment) ---
PAGE_TITLE=Status
TZ=UTC

# --- Optional (defaults in parentheses) ---
# PORT=8080
# POLL_INTERVAL_SECONDS=60
# HISTORY_DAYS=90
# ZABBIX_MIN_SEVERITY=0
# IMAGE_TAG=latest
# PUID=1000   # uid that owns ./data on the host (owner of the history files)
# PGID=1000
