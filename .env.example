# --- Zabbix (required) ---
ZABBIX_URL=https://zabbix.example.com/zabbix/
# Requires Zabbix >= 6.4 (token auth via the Authorization: Bearer header)
ZABBIX_TOKEN=put-your-api-token-here
ZABBIX_GROUPS_IDS=
ZABBIX_HOSTS_IDS=
ZABBIX_STATUS_BY_GROUPS=on
ZABBIX_KNOWLEDGES=on
ZABBIX_KNOWLEDGES_COMMENTS=on

# --- Presentation (comes from the container environment) ---
PAGE_TITLE=Status
TZ=UTC

# --- Link preview (Open Graph / WhatsApp / social) ---
# Description shown under the link when shared (WhatsApp, Telegram, social).
# PAGE_DESCRIPTION=Real-time availability of our services.
# Name of the site/organization (og:site_name). Defaults to PAGE_TITLE.
# PAGE_SITE_NAME=Example Org
# Preview image (og:image). Absolute URL, or a path served from public/
# (e.g. drop public/og-image.png and set /og-image.png). ~1200x630 px recommended.
# OG_IMAGE=/og-image.png
# Canonical public base URL (og:url + absolutizes a relative OG_IMAGE).
# If empty, it is derived from the incoming request (works behind a proxy).
# PUBLIC_URL=https://status.example.com

# --- Optional (defaults in parentheses) ---
# PORT=8080
# POLL_INTERVAL_SECONDS=60
# HISTORY_DAYS=90
# ZABBIX_MIN_SEVERITY=0
# Skip TLS verification for the Zabbix API (self-signed / incomplete chain).
# INSECURE — allows MITM. Prefer mounting the CA + NODE_EXTRA_CA_CERTS (see README).
# ZABBIX_TLS_INSECURE=off
# IMAGE_TAG=latest
# PUID=1000   # uid that owns ./data on the host (owner of the history files)
# PGID=1000
